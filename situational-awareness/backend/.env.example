APP_NAME=Asset Situational Awareness
APP_VERSION=0.1.0
API_V1_PREFIX=/api/v1
ENV=prod
SECRET_KEY=change-this-secret
ACCESS_TOKEN_EXPIRE_MINUTES=480
JWT_ALGORITHM=HS256
DATABASE_URL=postgresql+pg8000://asset:asset@postgres:5432/assetdb
REDIS_URL=redis://redis:6379/0
DEVICE_ALERTS_REDIS_CHANNEL=sa:device_abnormal_alerts
CORS_ALLOW_ALL=false
CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://192.168.*.*:3000,http://10.*.*.*:3000,http://172.16.*.*:3000,http://172.17.*.*:3000,http://172.18.*.*:3000,http://172.19.*.*:3000,http://172.20.*.*:3000,http://172.21.*.*:3000,http://172.22.*.*:3000,http://172.23.*.*:3000,http://172.24.*.*:3000,http://172.25.*.*:3000,http://172.26.*.*:3000,http://172.27.*.*:3000,http://172.28.*.*:3000,http://172.29.*.*:3000,http://172.30.*.*:3000,http://172.31.*.*:3000
LOCAL_ASSET_IPS=127.0.0.1,::1
SECURITY_ADMIN_CIDRS=
ENCRYPTION_KEY=
SETTINGS_HELPER_URL=http://settings-helper:8091/internal/apply
SETTINGS_HELPER_TOKEN=change-settings-helper-token
SETTINGS_HELPER_WORKSPACE_ROOT=/workspace
DISCOVERY_LIVENESS_PORTS=22,80,443,8080,8443
DISCOVERY_LIVENESS_MODE=multi_source
DISCOVERY_ENABLE_ARP_DISCOVERY=true
DISCOVERY_ENABLE_FPING=true
DISCOVERY_NMAP_HOST_DISCOVERY_PROFILE=balanced
DISCOVERY_SERVICE_PORTS=22,23,25,53,80,110,111,135,139,143,443,445,465,587,993,995,1433,1521,2049,2375,2376,3000,3306,3389,5432,5601,5672,5900,5984,6379,6443,7001,8000,8080,8081,8443,9000,9090,9200,9300,11211,27017
DISCOVERY_HIGH_BACKDOOR_PORTS=1337,4444,5555,6666,6667,6969,7007,10001,10008,12345,12346,16000,20001,30001,40001,50001,19191,20034,27374,31337,32764,54321,55555,60000,65000
DISCOVERY_PORTSET_MODE=top1000_plus_custom
DISCOVERY_TOP_PORTS_LIMIT=1000
DISCOVERY_NMAP_MIN_RATE=100000
DISCOVERY_NMAP_MODE=enrich
DISCOVERY_NMAP_TIMEOUT_SECONDS=8
DISCOVERY_NMAP_LIVENESS_TIMEOUT_SECONDS=90
DISCOVERY_NMAP_FULL_SCAN_TIMEOUT_SECONDS=90
DISCOVERY_NMAP_VERSION_INTENSITY=5
DISCOVERY_NSE_TIMEOUT_SECONDS=8
DISCOVERY_NSE_MODE=whitelist
DISCOVERY_NSE_HOST_CONCURRENCY=8
DISCOVERY_NSE_ENABLE_VULN_SCRIPTS=true
DISCOVERY_LOW_CONFIDENCE_THRESHOLD=70
DISCOVERY_FULL_SCAN_HOST_CONCURRENCY=8
DISCOVERY_FULL_SCAN_PORT_CONCURRENCY=256
DISCOVERY_SERVICE_PROBE_HOST_CONCURRENCY=32
CAMPUS_DEFAULT_PORTSET_MODE=top1000_plus_custom
CAMPUS_ALLOW_FULL_SCAN_DEFAULT=false
CAMPUS_ZONE_HOST_CONCURRENCY_LIMIT=8
CAMPUS_ZONE_NMAP_MIN_RATE=5000
CAMPUS_DHCP_DEFAULT_INTERVAL_SECONDS=1800
CAMPUS_SNMP_DEFAULT_INTERVAL_SECONDS=1800
CAMPUS_AUTO_BOOTSTRAP_ENABLED=true
CAMPUS_BOOTSTRAP_DHCP_LEASE_PATH=
RISK_ACTIVE_VERIFY_CONNECT_TIMEOUT_SECONDS=3
RISK_ACTIVE_VERIFY_READ_TIMEOUT_SECONDS=3
RISK_ACTIVE_VERIFY_MAX_CONCURRENCY=4
RUNNER_POLL_INTERVAL_SECONDS=10
RUNNER_OFFLINE_GRACE_SECONDS=45
REMEDIATION_AUTO_REVERIFY_ENABLED=true
REMEDIATION_STOP_ON_FAILURE=true
REMEDIATION_PREPARE_BACKUPS_ENABLED=true
LLM_PROVIDER=mock
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini
LLM_BASE_URL=
LLM_WIRE_API=responses
LLM_TIMEOUT_SECONDS=60
HAOR_REPLY_REWRITE_ENABLED=true
